# Scribbl — environment template. Copy to `.env.local` and fill in real values.
# `.env.local` is gitignored; this template is committed for onboarding.

# --- Client (Expo) — must be prefixed EXPO_PUBLIC_ to be readable in the app ---
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# RevenueCat public SDK keys (safe to ship). Leave blank to run in Expo Go
# (purchases are lazy-loaded and no-op without these).
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=appl_your_ios_key
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=goog_your_android_key

# --- Edge functions (Supabase) — set via `supabase secrets set`, NOT shipped ---
# ANTHROPIC_API_KEY lives ONLY server-side (the client never sees it):
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are auto-injected
# into every deployed function by Supabase — do not set them yourself.
ANTHROPIC_API_KEY=sk-ant-your-key
