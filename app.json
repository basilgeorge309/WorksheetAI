{
  "expo": {
    "name": "Scribbl",
    "slug": "scribbl",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "worksheetai",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scribbl.app",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.scribbl.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "worksheetai",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-sharing",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Scribbl needs camera access to photograph your worksheets."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Scribbl needs photo library access to upload your worksheets."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
